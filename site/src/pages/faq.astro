---
import Layout from "../layouts/Layout.astro";
import { getFaqItems } from "../lib/cms";

const faq = await getFaqItems();
---

<Layout title="test | FAQ">
  <section class="panel">
    <p class="eyebrow">FAQ</p>
    <h1>Frequently Asked Questions</h1>
    {faq.length === 0 ? (
      <p>No FAQ items are available yet. Add entries in Wix CMS.</p>
    ) : (
      <div class="faq-list">
        {faq.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    )}
  </section>
</Layout>

<style>
  .panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.5rem;
  }

  .eyebrow {
    margin: 0;
    color: var(--accent);
    font-size: 0.8rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    font-weight: 700;
  }

  h1 {
    margin: 0.4rem 0 1rem;
  }

  .faq-list {
    display: grid;
    gap: 0.75rem;
  }

  details {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.85rem 1rem;
    background: #fff;
  }

  summary {
    cursor: pointer;
    font-weight: 700;
  }

  details p {
    margin: 0.65rem 0 0;
    line-height: 1.55;
  }
</style>
